<header class="site-header">
  <div class="header-top">
    <a class="brand" href="<%- url_for('/') %>">
      <span class="brand-icon">✦</span>
      <span>
        <strong>RSMP S2 Wiki</strong>
        <small>祭坛季 · 荒野生存 · 生活系统重做</small>
      </span>
    </a>
    <div class="clock-chip">历法 | 769年1月1日 星期一 | 第1天 | 06:00</div>
  </div>
  <nav class="site-nav" aria-label="主导航">
    <% const menu = theme.menu || {}; %>
    <% Object.keys(menu).forEach(function(name){ %>
      <a href="<%- url_for(menu[name]) %>"><%= name %></a>
    <% }) %>
  </nav>
</header>
